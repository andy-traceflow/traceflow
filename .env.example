# Copy this file to .env for local dev. .env is gitignored — never commit real keys.
# In production (Render), set these in the dashboard's environment tab.

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
ENVIRONMENT=development              # development | staging | production
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
BASE_URL=http://localhost:8000       # public API base; used in webhook URL generation

# ---------------------------------------------------------------------------
# Supabase (single shared project, RLS-isolated per client_id)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=                # service role — admin operations, bypasses RLS
SUPABASE_ANON_KEY=                   # anon — for client SDK in admin/portal (Phase 3+)
SUPABASE_DB_URL=                     # direct Postgres URL for asyncpg pool (recommended)

# ---------------------------------------------------------------------------
# AI providers
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=                   # primary LLM for qualification + KB responses
OPENAI_API_KEY=                      # optional fallback / cheap-tier

# ---------------------------------------------------------------------------
# Twilio (SMS for LLR)
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Email (transactional)
# ---------------------------------------------------------------------------
RESEND_API_KEY=                      # primary transport for digests + alerts
NOTIFY_FROM_EMAIL=hello@traceflow.app

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
ADMIN_JWT_SECRET=                    # for internal admin endpoints (separate from per-client webhook secrets)
ALLOWED_ORIGINS=http://localhost:5173,https://app.traceflow.app

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
SENTRY_DSN=                          # optional; if set, errors get reported

# ---------------------------------------------------------------------------
# Per-client integration credentials (Monday, Shopify, etc.) live in
# client_configs.crm_credentials JSONB — they are NEVER global env vars.
# See migrations/001_create_clients_and_configs.sql for the schema.
# ---------------------------------------------------------------------------
